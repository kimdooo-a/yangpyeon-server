{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prevent-env-commit.sh \"$TOOL_INPUT\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/mcp-tool-guard.sh \"$TOOL_NAME\" \"$TOOL_INPUT\"",
            "timeout": 5
          }
        ]
      },
      {
        "_comment": "[비활성] spike-guard: src/ 수정 전 _SPIKE_CLEARANCE.md 존재 확인. 활성화하려면 matcher 주석 해제",
        "_disabled_matcher": "Write|Edit",
        "matcher": "__disabled__spike_guard__",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/spike-guard.sh \"$TOOL_INPUT\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh \"$TOOL_INPUT\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/load-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "코드 변경사항이 있으면 관련 테스트 실행을 제안하세요. 변경 없으면 아무 동작 하지 마세요."
          }
        ]
      }
    ]
  }
}
