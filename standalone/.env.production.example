# ─────────────────────────────────────────────────────────────────────
# 양평 부엌 대시보드 — standalone 운영 환경변수 템플릿
#
# 사용:  cp .env.production.example .env && vi .env
# 참조:  프로젝트 루트 .env.example + docs/handover/260419-session48-phase16a-vault.md
# ─────────────────────────────────────────────────────────────────────

# --- 핵심 인증 ---
DASHBOARD_PASSWORD=여기에_강한_비밀번호_입력

# --- 회원관리 v1 API ---
DATABASE_URL="postgresql://user:password@localhost:5432/luckystyle4u"
JWT_V1_SECRET="최소32자이상의시크릿키를여기에입력"
JWT_V1_REFRESH_SECRET="리프레시토큰용별도시크릿키"

# --- Vault / MFA 암호화 (세션 48 Phase 16a) ---
# VAULT_MASTER_KEY 는 Vault 로 이관되었지만, 부트스트랩을 위한 KEK 경로는 유지
# scripts/migrate-env-to-vault.ts 로 이관 후 삭제 가능
# VAULT_KEK_PATH=/var/lib/ypserver/kek.bin

# --- 파일박스 (선택) ---
# FILEBOX_DIR=/var/lib/ypserver/filebox
# FILEBOX_MAX_SIZE=52428800
# FILEBOX_TOTAL_LIMIT=524288000

# --- 런타임 ---
# PORT=3000
# HOSTNAME=0.0.0.0
# NODE_ENV=production  # start.sh / ecosystem.config.cjs 에서 자동 설정
