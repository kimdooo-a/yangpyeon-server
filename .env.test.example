# Messenger M2 통합 테스트 (`scripts/run-integration-tests.sh`) 용 환경 변수.
# 이 파일은 예시 — 실제 값은 `.env.test.local` (gitignored) 에 작성.
#
# 사전 조건:
#   1. WSL postgres 에 luckystyle4u_test DB 존재 (S82 에서 셋업 완료)
#   2. app_test_runtime role 존재 (BYPASSRLS=false, RLS GRANTs 적용)
#   3. 새 password 발급은 `bash scripts/setup-test-db-role.sh`

# app_test_runtime 의 password — RLS 가 적용되는 일반 user 역할.
RLS_TEST_RUNTIME_PASSWORD=

# postgres superuser password (BYPASSRLS, admin pool 시드 용).
# 보통 `~/ypserver/.env` 의 DATABASE_URL 패스워드와 동일.
RLS_TEST_ADMIN_PASSWORD=
