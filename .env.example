# 대시보드 인증
DASHBOARD_PASSWORD=여기에_강한_비밀번호_입력
# AUTH_SECRET (HS256 legacy) 는 세션 45 에서 제거됨. dashboard_session 은 ES256 JWKS 로 서명.

# 파일박스 (선택 — 기본값 사용 시 생략 가능)
# FILEBOX_DIR=/home/user/filebox
# FILEBOX_MAX_SIZE=52428800
# FILEBOX_TOTAL_LIMIT=524288000

# === 회원관리 (v1 API) ===
DATABASE_URL="postgresql://user:password@localhost:5432/luckystyle4u"
JWT_V1_SECRET="최소32자이상의시크릿키를여기에입력"
JWT_V1_REFRESH_SECRET="리프레시토큰용별도시크릿키"

# === Almanac Aggregator (Track B, T1~T9) ===
# spec: docs/research/baas-foundation/05-aggregator-migration/2026-04-26-plan.md §5
# 미설정 시 graceful degradation (LLM 보강 비활성화 + 외부 fetcher fallback)

# Gemini Flash 호출 키 — 미설정 시 규칙 분류만 동작 (classify.ts), LLM 보강 skip
GEMINI_API_KEY=

# Gemini 일일 호출 한도 (자정 KST 리셋). 비용 보수 = 200/일 (~$2/월 가정)
AGGREGATOR_LLM_DAILY_BUDGET=200

# fetcher User-Agent (RSS/HTML 스크랩 시 발신 표기)
AGGREGATOR_BOT_USER_AGENT="YangpyeongBot/1.0 (+https://stylelucky4u.com)"

# 소스 1회 fetch 최대 항목 수 (RSS/HTML/API 공통)
AGGREGATOR_MAX_ITEMS_PER_SOURCE=20

# Firecrawl 동적 스크랩 키 — kind=FIRECRAWL 소스 사용 시만 필수
FIRECRAWL_API_KEY=

# Product Hunt API 토큰 — parserConfig.token 폴백
PRODUCT_HUNT_TOKEN=
