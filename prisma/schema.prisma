generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// 멀티테넌트 BaaS 1급 시민 — ADR-022/023/026 ACCEPTED 2026-04-26.
/// Phase 0.3 (T0.3) Stage 1 additive: 본 모델 신설 + 'default' tenant 시드.
/// Phase 1.4 (T1.4) Stage 3 enforce: 모든 비즈니스 모델의 tenantId NOT NULL + RLS 정책 활성화.
///
/// id: UUID. 모든 비즈니스 모델의 tenant_id FK 가 본 컬럼을 참조 (Stage 3 부터).
/// slug: URL path 식별자 (예: "default", "almanac", "<2nd-consumer>"). /api/v1/t/<slug>/ 에 사용 (ADR-027).
/// status: active | suspended | archived. 운영 콘솔에서 토글 (ADR-026 §3 운영 토글).
/// runtimeOverrides: TS manifest 의 일부 필드 hot-override (Phase 2 Manifest loader 도입).
model Tenant {
  id               String   @id @default(uuid()) @db.Uuid
  slug             String   @unique
  displayName      String   @map("display_name")
  status           String   @default("active")
  runtimeOverrides Json?    @map("runtime_overrides")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  // Phase 1.5 (T1.5) backrefs — TenantWorkerPool + TenantCronPolicy + ApiKey K3 매칭.
  cronJobs   CronJob[]         @relation("TenantCronJobs")
  apiKeys    ApiKey[]          @relation("TenantApiKeys")
  cronPolicy TenantCronPolicy?
  // Phase 1.4+P0 (S61) — TenantMembership backref: cookie 인증 경로의 (tenantId, userId) 멤버십 조회.
  memberships TenantMembership[] @relation("TenantMemberships")

  @@map("tenants")
}

/// TenantMembership — cookie 인증 경로(/api/v1/t/<tenant>/*)의 (tenantId, userId) 멤버십 검증.
///
/// ADR-027 §4.3 + ADR-026 §멤버십. T1.2 router 가 fail-closed stub
/// (membership.ts) 으로 도입했고, 본 모델이 그 stub 의 빈자리(P0-membership)를 메운다.
///
/// **Tenant-bypass 모델** (spec §2.4 Tenant/JwksKey/SecretItem 카테고리):
///   - 멤버십 조회는 tenant context 가 *결정되기 전* 단계에서 일어남 (사용자가 어느 tenant 에 속하는지
///     판정하는 것이 본 query 의 목적) — RLS USING 절이 app.tenant_id 를 요구하면 self-defeating.
///   - 따라서 RLS 미적용. (tenantId, userId) 합성 unique + 명시 필터로 cross-tenant 안전성 보장.
///
/// role:
///   - "OWNER": tenant 의 단일 운영자 (주로 본인). admin 콘솔 로그인 가능.
///   - "ADMIN": OWNER 위임. (Phase 2 multi-admin 도입 시 사용)
///   - "MEMBER": 일반 컨슈머 사용자. (Almanac 등의 public 도메인 사용자)
///   - "VIEWER": read-only.
///
/// FK: ON DELETE CASCADE (Tenant 또는 User 삭제 시 자동 정리).
model TenantMembership {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id")
  role      String   @default("MEMBER")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  tenant Tenant @relation("TenantMemberships", fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation("UserTenantMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId], map: "tenant_memberships_tenant_id_user_id_key")
  @@index([userId])
  @@map("tenant_memberships")
}

model User {
  id             String                  @id @default(uuid())
  // Phase 1.4 Stage 3 deviation: 글로벌 email @unique 유지 (호출 사이트 호환 — login/register/users
  //   라우트가 findUnique({ where: { email } }) 사용). 추가로 (tenantId, email) 합성 unique 등록.
  //   Phase 1.4 후속 PR에서 호출 사이트를 (tenantId, email) findUnique 로 일괄 전환 후 글로벌 unique 제거 검토.
  email          String                  @unique
  passwordHash   String                  @map("password_hash")
  name           String?
  phone          String?
  role           Role                    @default(USER)
  isActive       Boolean                 @default(true) @map("is_active")
  mfaEnabled     Boolean                 @default(false) @map("mfa_enabled")
  lastLoginAt    DateTime?               @map("last_login_at") @db.Timestamptz(3)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default (current_setting('app.tenant_id')::uuid).
  // 마이그레이션 SQL 에서 backfill → SET NOT NULL → SET DEFAULT 순으로 적용.
  tenantId       String                  @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid
  folders        Folder[]                @relation("UserFolders")
  files          File[]                  @relation("UserFiles")
  sqlQueries     SqlQuery[]              @relation("UserSqlQueries")
  edgeFunctions  EdgeFunction[]          @relation("UserEdgeFunctions")
  apiKeys        ApiKey[]                @relation("UserApiKeys")
  sessions       Session[]               @relation("UserSessions")
  mfaEnrollment  MfaEnrollment?          @relation("UserMfaEnrollment")
  recoveryCodes  MfaRecoveryCode[]       @relation("UserMfaRecoveryCodes")
  authenticators WebAuthnAuthenticator[] @relation("UserAuthenticators")
  // Phase 1.4+P0 (S61) — 사용자가 속한 tenant 들의 멤버십 목록.
  tenantMemberships TenantMembership[]   @relation("UserTenantMemberships")

  // Phase 1.4 Stage 3 — tenant-scoped composite unique + index.
  @@unique([tenantId, email], map: "users_tenant_id_email_key")
  @@index([tenantId])
  @@map("users")
}

/// Phase 15 Auth Advanced — WebAuthn (Passkey) Authenticator (FR-6.2)
/// 참조: docs/research/2026-04-supabase-parity/02-architecture/03-auth-advanced-blueprint.md
/// SimpleWebAuthn v10 데이터 스키마 준용.
/// credentialId: base64url 인코딩된 credential ID. RP Unique.
/// publicKey: COSE 인코딩된 public key (byte[]).
/// counter: Replay 공격 방지용 signature counter. 서명마다 증가.
/// transports: AuthenticatorTransport[] JSON (internal/hybrid/usb/nfc/ble). 디스커버리 용.
/// deviceType: single_device(보안키, Touch ID 로컬) / multi_device(iCloud Passkey, Google Password Manager).
/// backedUp: 해당 자격증명이 클라우드 백업 상태인지 (cross-device 확장 가능 여부).
model WebAuthnAuthenticator {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  user         User      @relation("UserAuthenticators", fields: [userId], references: [id], onDelete: Cascade)
  // credentialId 는 RP 글로벌 ID — spec §2.3.8 에 따라 글로벌 @unique 유지.
  credentialId String    @unique @map("credential_id")
  publicKey    Bytes     @map("public_key")
  counter      BigInt    @default(0)
  transports   String[]  @default([])
  deviceType   String    @map("device_type")
  backedUp     Boolean   @map("backed_up")
  friendlyName String?   @map("friendly_name")
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId     String    @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  @@index([tenantId, userId])
  @@map("webauthn_authenticators")
}

/// WebAuthn 등록/어설션 챌린지 임시 저장 (단일 노드 가정 — 다중 노드면 Redis 이관).
/// 생성 시 만료 5분, 검증 시 즉시 삭제.
model WebAuthnChallenge {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  challenge String   @unique
  purpose   String // "registration" | "authentication"
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — spec §2.3.8: 등록 직전 tenant 미확정 케이스 → nullable 유지.
  // RLS 정책에서 별도 처리(WebAuthnChallenge 는 비즈니스 isolation 대상 아님 — Phase 4 재검토).
  tenantId  String?  @map("tenant_id") @db.Uuid

  @@index([expiresAt])
  @@map("webauthn_challenges")
}

/// Phase 15 Auth Advanced — TOTP MFA 등록 정보
/// 참조: docs/research/2026-04-supabase-parity/02-architecture/03-auth-advanced-blueprint.md (FR-6.1)
/// secretCiphertext: AES-256-GCM(MFA_MASTER_KEY)로 암호화된 TOTP secret. 평문 미저장.
///   format = nonce(12) || authTag(16) || ciphertext (base64url 인코딩).
/// confirmedAt: 사용자가 최초 OTP 검증에 성공한 시점. NULL 이면 enroll 미완료 (활성 아님).
/// failedAttempts: 챌린지 단계 실패 카운터. lockedUntil 초과 시 해제 (Rate Limit Step 6 전용).
model MfaEnrollment {
  id               String    @id @default(uuid())
  // userId @unique 유지 — User 1:1 MFA enrollment (User 가 이미 tenant-scoped).
  userId           String    @unique @map("user_id")
  user             User      @relation("UserMfaEnrollment", fields: [userId], references: [id], onDelete: Cascade)
  secretCiphertext String    @map("secret_ciphertext")
  confirmedAt      DateTime? @map("confirmed_at") @db.Timestamptz(3)
  failedAttempts   Int       @default(0) @map("failed_attempts")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamptz(3)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId         String    @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  @@index([tenantId])
  @@map("mfa_enrollments")
}

/// Phase 15 Auth Advanced — 일회용 복구 코드 (10개 발급, SHA-256 hash 저장).
/// 분실·변경 상황에서 MFA 우회 허용. 사용 즉시 usedAt 기록 (재사용 금지).
/// codeHash: SHA-256 hex (timing-safe 비교). 평문은 발급 시 1회만 사용자에게 노출.
model MfaRecoveryCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation("UserMfaRecoveryCodes", fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId  String    @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  // (userId, codeHash) 합성 unique 유지 — userId 가 이미 tenant-scoped 이므로 cross-tenant 충돌 없음.
  @@unique([userId, codeHash])
  @@index([tenantId, userId, usedAt])
  @@map("mfa_recovery_codes")
}

/// Phase 15 Auth Advanced — JWKS 키 저장소 (ES256 비대칭 서명)
/// 참조: docs/research/2026-04-supabase-parity/02-architecture/03-auth-advanced-blueprint.md §7.2.1
/// SP-014 실증: jose cacheMaxAge(180s)는 클라이언트 캐시만 제어 → grace는 "엔드포인트가 구·신 키 동시 서빙"으로 성립.
/// 키 회전 절차:
///   1. 신 키 등록 status=CURRENT, 구 키 status=RETIRED + retireAt = NOW() + max(token TTL, cacheMaxAge) + 60s.
///   2. JWKS 응답은 CURRENT + (RETIRED AND retireAt > NOW()) 동시 포함.
///   3. cron 1시간마다 retireAt < NOW() 건 DELETE (cleanup).
/// publicJwk/privateJwk: jose exportJWK 결과 (ES256 → EC P-256 형식).
/// privateJwk는 서버 내부에서만 사용, 응답에 절대 노출 금지.
model JwksKey {
  id         String     @id @default(uuid())
  kid        String     @unique
  alg        String     @default("ES256")
  publicJwk  Json       @map("public_jwk")
  privateJwk Json       @map("private_jwk")
  status     JwksStatus @default(CURRENT)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  rotatedAt  DateTime?  @map("rotated_at") @db.Timestamptz(3)
  retireAt   DateTime?  @map("retire_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — spec §2.4 Tenant-bypass: JWKS 는 단일 키셋 + JWT claim 으로 식별
  //   (현재 N=1 default tenant). nullable 유지 + RLS 미적용 (Phase 4 ADR-029 결정 시 재검토).
  tenantId   String?    @map("tenant_id") @db.Uuid

  @@index([status])
  @@index([retireAt])
  @@map("jwks_keys")
}

enum JwksStatus {
  CURRENT
  RETIRED
}

/// Phase 15 Auth Advanced Step 6 — DB-backed Rate Limit (FR-6.3)
/// 참조: docs/research/2026-04-supabase-parity/02-architecture/03-auth-advanced-blueprint.md
/// 정책: fixed-window. bucketKey(예: "v1Login:ip:1.2.3.4") 별 hits + windowStart 보유.
///   윈도우 만료 시(=now > windowStart + windowMs) hits 리셋.
/// 단일 노드 + PM2 cluster 워커 공유 방식. 다중 노드 확장 시 Redis 또는 별도 PG 인스턴스로 이관.
/// cleanup: 일 1회 windowStart < NOW() - INTERVAL '1 day' 삭제 (Sessions cleanup 패턴 동일).
model RateLimitBucket {
  // bucketKey 는 이미 namespacing(예: "<tenantId>:<scope>:..." spec §2.3.9) 이지만,
  // RLS 정책 일관성을 위해 tenant_id 컬럼도 보유.
  bucketKey   String   @id @map("bucket_key")
  hits        Int      @default(1)
  windowStart DateTime @default(now()) @map("window_start") @db.Timestamptz(3)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId    String   @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  @@index([tenantId, windowStart])
  @@map("rate_limit_buckets")
}

/// Phase 15 Auth Advanced — 사용자 세션 (DB-backed, opaque token)
/// 참조: docs/research/2026-04-supabase-parity/02-architecture/03-auth-advanced-blueprint.md §7.2.2
/// SP-015 결과: PG partial index + NOW() 불가 → 일반 복합 인덱스 (user_id, revoked_at, expires_at)
///   + cleanup job (일 1회 DELETE WHERE expires_at < NOW() - INTERVAL '1 day') 채택.
/// tokenHash는 SHA-256 hex of opaque token (평문 미저장). p95 48μs (100k rows, SP-015 실측).
model Session {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  // tokenHash 는 SHA-256 hex (글로벌 충돌 0 가정) — 글로벌 @unique 유지.
  tokenHash     String    @unique @map("token_hash")
  ip            String?
  userAgent     String?   @map("user_agent")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  lastUsedAt    DateTime  @default(now()) @map("last_used_at") @db.Timestamptz(3)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(3)
  // 세션 37 — revoke 사유 추적. "rotation" 만 reuse 의심 대상, 나머지(self/logout/reuse/admin)는 조용히 401.
  revokedReason String?   @map("revoked_reason")
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId      String    @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  // spec §2.3.2 — (userId, revokedAt, expiresAt) → (tenantId, userId, revokedAt, expiresAt) 재설계.
  @@index([tenantId, userId, revokedAt, expiresAt])
  @@map("sessions")
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  parentId  String?  @map("parent_id")
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderTree")
  ownerId   String   @map("owner_id")
  owner     User     @relation("UserFolders", fields: [ownerId], references: [id])
  files     File[]
  isRoot    Boolean  @default(false) @map("is_root")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId  String   @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  // spec §2.3.3 — 기존 (parentId, name, ownerId) → (tenantId, parentId, name, ownerId).
  // ownerId 가 이미 tenant-scoped 이므로 cross-tenant 충돌 0 — 그래도 인덱스 일관성 위해 prepend.
  @@unique([tenantId, parentId, name, ownerId])
  @@index([tenantId])
  @@map("folders")
}

model File {
  id           String   @id @default(uuid())
  originalName String   @map("original_name")
  // storedName 은 UUID 기반 — 글로벌 @unique 유지 (spec §2.3.4).
  storedName   String   @unique @map("stored_name")
  size         Int
  mimeType     String   @map("mime_type")
  folderId     String   @map("folder_id")
  folder       Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  ownerId      String   @map("owner_id")
  owner        User     @relation("UserFiles", fields: [ownerId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId     String   @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  @@index([tenantId, folderId])
  @@map("files")
}

enum Role {
  ADMIN
  MANAGER
  USER
}

// ─────────────────────────────────────────────────────────────
// 세션 14: Supabase 관리 체계 이식 — 추가 모델
// 참고: docs/research/decisions/ADR-002-supabase-adaptation-strategy.md
// ─────────────────────────────────────────────────────────────

/// SQL Editor에서 저장한 쿼리
model SqlQuery {
  id        String     @id @default(uuid())
  name      String
  sql       String
  scope     QueryScope @default(PRIVATE)
  ownerId   String     @map("owner_id")
  owner     User       @relation("UserSqlQueries", fields: [ownerId], references: [id], onDelete: Cascade)
  lastRunAt DateTime?  @map("last_run_at") @db.Timestamptz(3)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId  String     @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  @@index([tenantId, ownerId, scope])
  @@map("sql_queries")
}

/// Edge Functions (lite) — 사용자가 등록한 코드 스니펫
model EdgeFunction {
  id          String            @id @default(uuid())
  // Phase 1.4 Stage 3 deviation — 글로벌 @unique 유지 + (tenantId, name) 합성 unique 추가.
  // 호출 사이트가 prisma.edgeFunction.findUnique({ where: { name } }) 형태를 사용할 가능성 보존.
  // 후속 PR 에서 호출 사이트 일괄 전환 후 글로벌 unique 제거 검토 (spec §2.3.6).
  name        String            @unique
  description String?
  code        String
  runtime     FunctionRuntime   @default(NODE_VM)
  enabled     Boolean           @default(true)
  ownerId     String            @map("owner_id")
  owner       User              @relation("UserEdgeFunctions", fields: [ownerId], references: [id])
  runs        EdgeFunctionRun[]
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId    String            @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  @@unique([tenantId, name], map: "edge_functions_tenant_id_name_key")
  @@index([tenantId, ownerId])
  @@map("edge_functions")
}

/// Edge Function 실행 로그
model EdgeFunctionRun {
  id         String       @id @default(uuid())
  functionId String       @map("function_id")
  function   EdgeFunction @relation(fields: [functionId], references: [id], onDelete: Cascade)
  status     RunStatus
  durationMs Int?         @map("duration_ms")
  stdout     String?
  stderr     String?
  startedAt  DateTime     @default(now()) @map("started_at") @db.Timestamptz(3)
  finishedAt DateTime?    @map("finished_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId   String       @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  @@index([tenantId, functionId, startedAt])
  @@map("edge_function_runs")
}

/// Database Webhook — 테이블 이벤트 → HTTP 호출
model Webhook {
  id              String       @id @default(uuid())
  name            String
  sourceTable     String       @map("source_table")
  event           WebhookEvent
  url             String
  headers         Json         @default("{}")
  secret          String?
  enabled         Boolean      @default(true)
  lastTriggeredAt DateTime?    @map("last_triggered_at") @db.Timestamptz(3)
  failureCount    Int          @default(0) @map("failure_count")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId        String       @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  @@index([tenantId, sourceTable, event])
  @@map("webhooks")
}

/// Cron Job — 주기 실행 작업
/// Phase 1.5 (T1.5): TenantWorkerPool + circuit breaker 도입.
/// 추가 컬럼: consecutiveFailures, circuitState, circuitOpenedAt, lastSuccessAt — 07-adr-028-impl-spec §7.1.
model CronJob {
  id                  String    @id @default(uuid())
  // Phase 1.4 Stage 3 deviation — 글로벌 @unique 유지 + (tenantId, name) 합성 unique 추가.
  // 호출 사이트 호환 보존 (spec §2.3.7). 후속 PR 에서 글로벌 unique 제거 검토.
  name                String    @unique
  schedule            String
  kind                CronKind
  payload             Json      @default("{}")
  enabled             Boolean   @default(true)
  lastRunAt           DateTime? @map("last_run_at") @db.Timestamptz(3)
  lastStatus          String?   @map("last_status")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default. T1.5 의 nullable FK 는 NOT NULL FK 로 전환.
  tenantId            String    @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid
  // Phase 1.5 circuit breaker — 07-adr-028-impl-spec §7.1.
  // consecutiveFailures: recordResult 가 실패마다 +1, 성공 시 0 으로 리셋.
  // circuitState: CLOSED | OPEN | HALF_OPEN. shouldDispatch 가 본 컬럼으로 게이트.
  // circuitOpenedAt: OPEN 진입 시각. cooldown 경과 판정에 사용.
  // lastSuccessAt: 마지막 성공 시각 (운영 콘솔 표시용).
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  circuitState        String    @default("CLOSED") @map("circuit_state")
  circuitOpenedAt     DateTime? @map("circuit_opened_at") @db.Timestamptz(3)
  lastSuccessAt       DateTime? @map("last_success_at") @db.Timestamptz(3)

  // Phase 1.4 Stage 3 — NOT NULL FK 로 전환. cron_jobs.tenant_id 는 RLS 정책 게이트의 핵심.
  // onDelete: Cascade — Tenant 제거 시 본 cron 도 일괄 정리 (운영 콘솔 SUSPENDED 토글로 사전 차단 가정).
  tenant Tenant @relation("TenantCronJobs", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name], map: "cron_jobs_tenant_id_name_key")
  @@index([tenantId, enabled])
  @@index([circuitState, circuitOpenedAt])
  @@map("cron_jobs")
}

/// Phase 1.5 (T1.5) — TenantCronPolicy
/// 07-adr-028-impl-spec §7.1 — cron 실행 정책의 단일 진실 소스 (per-tenant override).
/// row 부재 시 DEFAULT_POLICY (코드 상수) fallback.
/// 운영 콘솔에서 컨슈머별 토글 (concurrency cap, timeout, memory limit, allowed hosts).
model TenantCronPolicy {
  tenantId                    String   @id @map("tenant_id") @db.Uuid
  /// per-tenant 동시 실행 cron 개수 캡 (main thread 게이트)
  maxConcurrentJobs           Int      @default(3) @map("max_concurrent_jobs")
  /// per-job timeout (worker.terminate 트리거)
  jobTimeoutMs                Int      @default(30000) @map("job_timeout_ms")
  /// resourceLimits.maxOldGenerationSizeMb — 약한 heap cap
  jobMemoryLimitMb            Int      @default(128) @map("job_memory_limit_mb")
  /// circuit breaker OPEN 진입 임계값 (default 5)
  consecutiveFailureThreshold Int      @default(5) @map("consecutive_failure_threshold")
  /// 분당 tick 한도 (운영 모니터링 — 실 정책에 직접 사용 X, 대시보드 안내치)
  ticksPerDay                 Int      @default(1440) @map("ticks_per_day")
  /// 컨슈머별 fetch 화이트리스트 (FUNCTION/WEBHOOK 격리)
  allowedFetchHosts           String[] @default([]) @map("allowed_fetch_hosts")
  /// WEBHOOK fetch 타임아웃
  webhookTimeoutMs            Int      @default(60000) @map("webhook_timeout_ms")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_cron_policies")
}

/// API Keys — publishable/secret 이중화. keyHash만 저장, 평문은 발급 시 1회 노출.
model ApiKey {
  id         String     @id @default(uuid())
  name       String
  // prefix 는 발급 시 충돌 회피로 글로벌 @unique 유지 (spec §2.3.5).
  prefix     String     @unique
  keyHash    String     @unique @map("key_hash")
  type       ApiKeyType
  scopes     String[]
  ownerId    String     @map("owner_id")
  owner      User       @relation("UserApiKeys", fields: [ownerId], references: [id])
  lastUsedAt DateTime?  @map("last_used_at") @db.Timestamptz(3)
  revokedAt  DateTime?  @map("revoked_at") @db.Timestamptz(3)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default. ADR-027 K3 매칭 강제.
  tenantId   String     @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  // Phase 1.4 Stage 3 — NOT NULL FK 로 전환. T1.3 의 K3 cross-validation 보강.
  tenant Tenant @relation("TenantApiKeys", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, prefix])
  @@index([tenantId, revokedAt])
  @@index([tenantId, ownerId])
  @@map("api_keys")
}

/// Log Drains — 외부 관측 플랫폼으로 로그 전송
model LogDrain {
  id              String    @id @default(uuid())
  name            String
  type            DrainType
  url             String
  authHeader      String?   @map("auth_header")
  filters         Json      @default("{}")
  enabled         Boolean   @default(true)
  lastDeliveredAt DateTime? @map("last_delivered_at") @db.Timestamptz(3)
  failureCount    Int       @default(0) @map("failure_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — NOT NULL + dbgenerated default.
  tenantId        String    @default(dbgenerated("(current_setting('app.tenant_id'))::uuid")) @map("tenant_id") @db.Uuid

  @@index([tenantId])
  @@map("log_drains")
}

enum QueryScope {
  PRIVATE
  SHARED
  FAVORITE
}

enum FunctionRuntime {
  NODE_VM
  WORKER_THREAD
}

enum RunStatus {
  SUCCESS
  FAILURE
  TIMEOUT
}

enum WebhookEvent {
  INSERT
  UPDATE
  DELETE
  ANY
}

enum CronKind {
  SQL
  FUNCTION
  WEBHOOK
}

enum ApiKeyType {
  PUBLISHABLE
  SECRET
}

enum DrainType {
  HTTP
  LOKI
  WEBHOOK
}

/// Phase 16a Vault — envelope 암호화된 시크릿 저장소 (ADR-020)
/// 참조: docs/superpowers/specs/2026-04-19-phase-16-design.md §16a
/// MASTER_KEY (KEK) 로 DEK 없이 직접 암호화 (Hybrid 경량 envelope).
///   encryptedValue = AES-256-GCM(MASTER_KEY, iv)(plaintext)
///   tag = GCM auth tag (tamper 탐지, SP-017 검증)
/// kekVersion: rotateKek 수행 시 증가. 구 버전 row 는 신 MASTER_KEY 로 재암호화 후 갱신.
/// name: 조회 키 (예: "mfa.master_key", "jwks.active_kid"). @unique — name 기준 단일 버전 유지.
model SecretItem {
  id             String    @id @default(cuid())
  name           String    @unique
  encryptedValue Bytes     @map("encrypted_value")
  iv             Bytes
  tag            Bytes
  kekVersion     Int       @default(1) @map("kek_version")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  rotatedAt      DateTime? @map("rotated_at") @db.Timestamptz(3)
  // Phase 1.4 Stage 3 — spec §2.4 Tenant-bypass: SecretItem (Vault) 은 환경 전역 (MFA_MASTER_KEY 등).
  //   nullable 유지 + RLS 미적용. KEK 격리는 Phase 4 별도 ADR.
  tenantId       String?   @map("tenant_id") @db.Uuid

  @@map("secret_items")
}
