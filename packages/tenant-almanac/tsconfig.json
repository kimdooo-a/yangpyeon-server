{
  "extends": "../core/tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "paths": {
      "@yangpyeon/core": ["../core/src/index.ts"],
      "@yangpyeon/core/*": ["../core/src/*"]
    }
  },
  "include": ["manifest.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules"]
}
